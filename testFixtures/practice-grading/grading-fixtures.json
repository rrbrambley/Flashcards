    },
    {
      "name": "non-zero card index uses that card as the correct answer",
      "cards": [
        { "question": "France", "answer": "Paris" },
        { "question": "Japan", "answer": "Tokyo" },
        { "question": "Italy", "answer": "Rome" },
        { "question": "Spain", "answer": "Madrid" },
        { "question": "Germany", "answer": "Berlin" }
      ],
      "cardIndex": 2,
      "count": 4,
      "expectedSize": 4,
      "correct": "Rome",
      "allowedDistractors": ["Paris", "Tokyo", "Madrid", "Berlin"]
    }
  ]
}
