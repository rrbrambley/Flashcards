{
  "_comment": "Canonical, source-of-truth golden vectors that pin the practice-mode grading logic to identical behavior across platforms. The web (TypeScript: webApp/src/practice/grading/) and mobile (shared Kotlin: shared/.../practice/grading/) keep separate implementations by design — :shared has no Kotlin/JS target — so both test suites load THIS file and assert against it. A change to the threshold or choice rules on only one side then fails that side's test (drift is caught in CI). Readers: webApp/src/practice/grading/parity.test.ts (node:fs) and shared/src/jvmTest/.../GradingParityFixtureTest.kt (classpath resource). See FLA-81.",

  "textGrading": [
    {
      "name": "exact match",
      "input": "Paris",
      "answer": "Paris",
      "expectedCorrect": true,
      "expectedSimilarity": 1.0
    },
    {
      "name": "ignores case and surrounding whitespace",
      "input": "  pARiS ",
      "answer": "Paris",
      "expectedCorrect": true,
      "expectedSimilarity": 1.0
    },
    {
      "name": "collapses internal whitespace",
      "input": "new   york",
      "answer": "New York",
      "expectedCorrect": true,
      "expectedSimilarity": 1.0
    },
    {
      "name": "typo within tolerance (one missing letter, ~0.909)",
      "input": "Mississipi",
      "answer": "Mississippi",
      "expectedCorrect": true,
      "expectedSimilarity": 0.9090909090909091
    },
    {
      "name": "exactly at the 0.85 threshold (3 edits over 20 chars) is correct",
      "input": "abcdefghijklmnopqrst",
      "answer": "abcdefghijklmnopqxyz",
      "expectedCorrect": true,
      "expectedSimilarity": 0.85
    },
    {
      "name": "just below the threshold (4 edits over 20 chars = 0.80) is incorrect",
      "input": "abcdefghijklmnopqrst",
      "answer": "abcdefghijklmnopwxyz",
      "expectedCorrect": false,
      "expectedSimilarity": 0.8
    },
    {
      "name": "below tolerance, equal length",
      "input": "cat",
      "answer": "dog",
      "expectedCorrect": false,
      "expectedSimilarity": 0.0
    },
    {
      "name": "below tolerance, different words",
      "input": "Berlin",
      "answer": "Paris",
      "expectedCorrect": false
    },
    {
      "name": "empty input against a real answer",
      "input": "",
      "answer": "Paris",
      "expectedCorrect": false,
      "expectedSimilarity": 0.0
    },
    {
      "name": "whitespace-only input normalizes to empty",
      "input": "   ",
      "answer": "Paris",
      "expectedCorrect": false,
      "expectedSimilarity": 0.0
    },
    {
      "name": "both empty normalize equal (maxLen 0 short-circuits to 1.0)",
      "input": "",
      "answer": "",
      "expectedCorrect": true,
      "expectedSimilarity": 1.0
    },
    {
      "name": "alternative answer: exact match on an alternative (primary differs)",
      "input": "NYC",
      "answer": "New York",
      "alternativeAnswers": ["NYC", "New York City"],
      "expectedCorrect": true,
      "expectedSimilarity": 1.0
    },
    {
      "name": "alternative answer: fuzzy match on an alternative within tolerance (~0.909)",
      "input": "Mississipi",
      "answer": "Spain",
      "alternativeAnswers": ["Mississippi"],
      "expectedCorrect": true,
      "expectedSimilarity": 0.9090909090909091
    },
    {
      "name": "alternative answer: matches neither the primary nor any alternative",
      "input": "Berlin",
      "answer": "Paris",
      "alternativeAnswers": ["Lyon", "Nice"],
      "expectedCorrect": false
    },
    {
      "name": "alternative answer: best similarity across primary + alternatives is taken",
      "input": "Paris",
      "answer": "Lyon",
      "alternativeAnswers": ["Marseille", "Paris"],
      "expectedCorrect": true,
      "expectedSimilarity": 1.0
    },
    {
      "name": "alternative answer: blank alternatives are ignored (empty input stays incorrect)",
      "input": "",
      "answer": "Paris",
      "alternativeAnswers": ["", "   "],
      "expectedCorrect": false,
      "expectedSimilarity": 0.0
    }
  ],

  "multipleChoice": [
