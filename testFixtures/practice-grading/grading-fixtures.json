    },
    {
      "name": "count of 1 yields only the correct answer",
      "cards": [
        { "question": "France", "answer": "Paris" },
        { "question": "Japan", "answer": "Tokyo" },
        { "question": "Italy", "answer": "Rome" },
        { "question": "Spain", "answer": "Madrid" },
        { "question": "Germany", "answer": "Berlin" }
      ],
      "cardIndex": 0,
      "count": 1,
