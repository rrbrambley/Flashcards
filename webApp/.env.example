# Copy this file to `.env` and fill in your values:  cp .env.example .env
# (`.env` is gitignored; Vite loads it automatically at dev/build time.)

# Base URL of the running backend. The default below works when the backend
# runs locally on the same machine as the web dev server.
VITE_API_BASE_URL=http://localhost:8080

# OAuth Web client ID for "Sign in with Google". Leave blank to hide the Google
# button (email/password sign-in still works). Use the SAME client ID the backend
# verifies against (GOOGLE_WEB_CLIENT_ID). See README.md ("Sign in with Google").
VITE_GOOGLE_WEB_CLIENT_ID=
